{
  "type": "project",
  "require": {
    "php": ">=7.3",
    "ext-curl": "*",
    "ext-gd": "*",
    "ext-intl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-mysqli": "*",
    "ext-pdo": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "classmap": [],
    "files": []
  },
  "autoload-dev": {
    "psr-4": {}
  },
  "prefer-stable": true,
  "scripts": {
    "post-update-cmd": [
      "@composer dump-autoload"
    ],
    "test": "phpunit"
  }
}